# https://editorconfig.org — keeps whitespace consistent across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.swift]
indent_size = 4
max_line_length = 120

[*.{yml,yaml,json,md}]
indent_size = 2

[*.sh]
indent_size = 4
